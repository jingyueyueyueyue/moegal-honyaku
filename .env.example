DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen3-max
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai-proxy.org/v1
OPENAI_MODEL=gpt-5-mini
MOEGAL_USE_GPU=0

# ============ OCR 引擎配置 ============
# OCR 引擎选择：manga_ocr（仅日文）, paddle_ocr（多语言）, auto（自动检测）
OCR_ENGINE=auto
# PaddleOCR 语言设置：japan, en, ch, korean 等
PADDLE_OCR_LANG=japan
# 是否使用 PaddleOCR 轻量级模型（推荐CPU环境开启）
PADDLE_OCR_LITE=true

# ============ OCR 高级优化 ============
# 是否启用OCR图像预处理（降噪+对比度+锐化）
OCR_PREPROCESS=true
# 是否启用OCR后处理（清理噪声字符）
OCR_POSTPROCESS=true
# OCR 置信度过滤阈值（PaddleOCR，0-1）
OCR_CONF_THRESHOLD=0.5
# 是否启用文本方向自动校正
OCR_AUTO_ROTATE=true

# ============ OCR 并发配置 ============
OCR_MAX_CONCURRENCY=2

# ===== YOLO 文本检测参数 =====
# 置信度阈值：越低检测越多文字区域（默认0.25，范围0.1-0.5）
DET_CONF_THRESHOLD=0.25
# IOU 阈值：合并重叠框（默认0.5）
DET_IOU_THRESHOLD=0.5
# 检测图像尺寸：越大越精确但越慢（默认1024，范围512-2048）
DET_IMG_SIZE=1024
# 是否增强对比度预处理
DET_ENHANCE_CONTRAST=true

# ===== Inpaint 参数 =====
# 修复半径：越大修复范围越广（默认8，范围5-15）
INPAINT_RADIUS=8
# 修复算法：NS（质量更好）或 TELEA（速度更快）
INPAINT_METHOD=NS
# 是否对修复边缘进行模糊处理
INPAINT_BLUR_EDGE=true
# 是否进行二次修复（针对顽固残留）
DOUBLE_INPAINT=true

# ===== 掩码参数 =====
# 掩码膨胀迭代次数（默认3，范围1-5）
MASK_DILATE_ITERATIONS=3
# 掩码膨胀核大小（默认7，范围3-9）
MASK_DILATE_KERNEL_SIZE=7
# 全局掩码扩展像素（默认4，范围0-10）
GLOBAL_MASK_EXPAND=4
# 是否使用增强版掩码算法（多策略融合）
USE_ENHANCED_MASK=true

# ===== 边界框参数 =====
# 边界框扩展像素：确保完全覆盖文字边缘（默认5，范围0-15）
BBOX_PADDING=5
