# ============================================================
#                    服务器配置
# ============================================================
# 服务监听端口（默认 8000）
SERVER_PORT=8000

# ============================================================
#                    翻译服务配置
# ============================================================
# DashScope（阿里云通义千问）配置
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen3-max

# OpenAI 配置
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai-proxy.org/v1
OPENAI_MODEL=gpt-5-mini

# ============ 翻译提示词配置（可自定义）============
# 单句翻译提示词（parallel 模式使用）
# 默认：将句子翻译成中文，保留自然对话风格
TRANSLATE_SYSTEM_PROMPT=将句子翻译成中文（如果是符号就直接输出，不要加任何解释、注解或括号内容，仅保留自然对话或原声风格的翻译。）
# 批量翻译提示词（structured 模式使用）
# 默认：接收 JSON 数组，返回翻译结果 JSON
TRANSLATE_STRUCTURED_PROMPT=你会收到一个 JSON 数组，每项是待翻译句子。请返回 JSON：{"result": ["翻译1", "翻译2", ...]}。只输出 JSON，不要输出任何多余文本。

# ============================================================
#                    OCR 引擎选择
# ============================================================
# 启动时默认 OCR 引擎（通过 start.cmd 选择会自动设置此变量）
# - local: 本地模型（MangaOCR/PaddleOCR），需要下载模型约 500MB
# - vision: 多模态模型 OCR，无需本地模型，但需要 API 调用费用
# 运行时仍可通过 API 切换：
#   curl -X POST "http://127.0.0.1:8000/conf/update" -H "Content-Type: application/json" -d '{"attr":"ocr_engine","v":"vision"}'
# MOEGAL_OCR_ENGINE=local

# ============================================================
#               本地 OCR 模型配置（ocr_engine=local）
# ============================================================
# 本地 OCR 引擎细分选择：
# - manga_ocr: 仅支持日文，准确率高
# - paddle_ocr: 支持多语言（日/英/中/韩等）
# - auto: 自动检测语言，优先用 MangaOCR，英文时回退 PaddleOCR
OCR_ENGINE=auto
# PaddleOCR 语言设置：japan（日文）, en（英文）, ch（中文）, korean（韩文）等
PADDLE_OCR_LANG=japan
# 是否使用 PaddleOCR 轻量级模型（推荐 CPU 环境开启，速度更快）
PADDLE_OCR_LITE=true

# ============ OCR 高级优化 ============
# 是否启用 OCR 图像预处理（降噪 + 对比度增强 + 锐化）
# 开启后可提升模糊/低质量图片的识别准确率，但会增加处理时间
OCR_PREPROCESS=true
# 是否启用 OCR 后处理（清理噪声字符，如多余的竖线、重复字符等）
OCR_POSTPROCESS=true
# OCR 置信度过滤阈值，仅对 PaddleOCR 生效（范围 0-1，低于此值的结果会被过滤）
OCR_CONF_THRESHOLD=0.5
# 是否启用文本方向自动校正（识别倾斜/旋转的文字）
OCR_AUTO_ROTATE=true

# ============ OCR 并发配置 ============
# OCR 并发线程数（默认 2，建议 CPU 核心数 - 1）
# 多模态模式下建议降低此值，避免 API 限流
OCR_MAX_CONCURRENCY=2

# ============================================================
#              多模态 OCR 配置（ocr_engine=vision）
# ============================================================
# 多模态 API 供应商：openai 或 dashscope
# 注意：选择后会使用下方对应的 API 配置
VISION_OCR_PROVIDER=openai

# OpenAI Vision OCR 配置（VISION_OCR_PROVIDER=openai 时使用）
# 如需使用与翻译服务相同的 OpenAI 配置，可填写相同值
VISION_OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
VISION_OPENAI_BASE_URL=https://api.openai.com/v1
# 多模态模型名称（需支持视觉能力）
# - OpenAI 官方: gpt-4o, gpt-4o-mini（推荐，性价比高）
# - 第三方兼容: 根据实际部署填写，如 Qwen2-VL-7B-Instruct 等
VISION_OCR_MODEL=gpt-4o-mini

# DashScope Vision OCR 配置（VISION_OCR_PROVIDER=dashscope 时使用）
VISION_DASHSCOPE_API_KEY=
VISION_DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 多模态模型名称
# - qwen-vl-plus: 性价比高，适合大多数场景
# - qwen-vl-max: 效果最好，价格稍高
VISION_DASHSCOPE_MODEL=qwen-vl-plus

# OCR 提示词（可自定义，一般无需修改）
# 要求模型仅输出识别的文字，不翻译、不解释
VISION_OCR_PROMPT=请识别这张图片中的所有文字，只输出识别到的文字内容，不要添加任何解释、翻译或格式化。如果有多行文字，用换行符分隔。如果没有文字，返回空字符串。

# ============================================================
#                  YOLO 文本检测参数
# ============================================================
# 置信度阈值：越低检测越多文字区域，但可能有误检（默认 0.25，范围 0.1-0.5）
DET_CONF_THRESHOLD=0.25
# IOU 阈值：用于合并重叠的检测框（默认 0.5）
DET_IOU_THRESHOLD=0.5
# 检测图像尺寸：越大检测越精确但越慢（默认 1024，范围 512-2048）
DET_IMG_SIZE=1024
# 是否在检测前增强对比度（对低对比度图片有帮助）
DET_ENHANCE_CONTRAST=true

# ============================================================
#                    Inpaint 修复参数
# ============================================================
# 修复半径：影响擦除文字时的边缘平滑度（默认 3，范围 2-5）
INPAINT_RADIUS=3
# 修复算法：NS（Navier-Stokes，质量更好但慢）或 TELEA（快速，推荐）
INPAINT_METHOD=TELEA
# 是否进行二次 inpaint（修复效果更好，但耗时翻倍）
DOUBLE_INPAINT=false

# ============================================================
#                      掩码参数
# ============================================================
# 掩码膨胀迭代次数：越大文字覆盖越完整，但可能侵蚀背景（默认 1，范围 1-3）
MASK_DILATE_ITERATIONS=1
# 掩码膨胀核大小（默认 3，范围 2-5）
MASK_DILATE_KERNEL_SIZE=3
# 是否使用增强版掩码算法（对复杂背景效果更好，但耗时增加）
# 适用场景：渐变背景、噪点较多的漫画
USE_ENHANCED_MASK=false

# ============================================================
#                     边界框参数
# ============================================================
# 边界框扩展像素：确保文字完全被覆盖（默认 2，范围 0-5）
BBOX_PADDING=2

# ============================================================
#                   翻译接口参数
# ============================================================
# /api/v1/translate/web 接口请求体最大字节数（默认 20MB）
# 如果前端发送大型 canvas PNG，可能需要调大此值
TRANSLATE_WEB_MAX_BODY_BYTES=20971520

# ============================================================
#                   翻译重试机制
# ============================================================
# 翻译请求失败时自动重试，使用指数退避策略避免雪崩
# 最大重试次数（默认 3 次，设为 1 则不重试）
RETRY_MAX_ATTEMPTS=3
# 初始重试延迟，单位秒（默认 1 秒）
RETRY_INITIAL_DELAY=1.0
# 重试延迟倍数（默认 2，即 1s -> 2s -> 4s ...）
RETRY_BACKOFF_MULTIPLIER=2.0
# 重试延迟最大值，单位秒（默认 30 秒）
RETRY_MAX_DELAY=30.0

# ============================================================
#                   AI 智能断句
# ============================================================
# AI断句：翻译后自动优化换行，使文本更适合漫画气泡显示
# 注意：AI断句会复用翻译模型，无需单独配置模型
# 是否启用 AI 智能断句（默认启用）
AI_LINEBREAK_ENABLED=true
# 触发 AI 断句的最小文本长度（默认 50 字符，短文本不处理）
AI_LINEBREAK_MIN_LENGTH=50

# ============================================================
#                     图片保存配置
# ============================================================
# 是否自动保存翻译前后的图片到 saved/ 目录（默认关闭）
# 开启后会保存原始图片和翻译结果，便于调试和记录
AUTO_SAVE_IMAGE=false